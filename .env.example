# ─── Server ───────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────
# Local:  mongodb://localhost:27017/safestay
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/safestay
MONGO_URI=

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Client Origin (for CORS) ─────────────────────────────
CLIENT_URL=http://localhost:5173
